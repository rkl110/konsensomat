# Adresse, auf der der Server lauscht (z.B. ":8080" oder "0.0.0.0:8000")
KONSENSOMAT_ADDR=:8080

# Verzeichnis, in dem die Umfrage-Daten als JSON-Dateien abgelegt werden
KONSENSOMAT_DATA_DIR=files/data

# Maximale (und vorausgewählte) Laufzeit einer Umfrage in Tagen (maximal
# 365); die Erstellerin/der Ersteller kann beim Anlegen eine kürzere
# Laufzeit wählen
KONSENSOMAT_EXPIRY_DAYS=7

# Optionales Admin-Passwort: wer es kennt, kann sich unter /admin anmelden
# und danach jede Umfrage einsehen und löschen, unabhängig von deren eigenem
# Passwort. Leer/auskommentiert lassen, um die Admin-Funktion zu deaktivieren.
#KONSENSOMAT_ADMIN_PASSWORD=
